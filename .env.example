# Configuración general
HOST=0.0.0.0
PORT=5002
DEBUG=true
SECRET_KEY=cambia-esto-en-produccion

# GitHub (usuario que recibe el repo)
GITHUB_USER=tu-usuario

# Nextcell / Mercado Libre (si aplica)
nextcell_user=tu-usuario
nextcell_password=tu-password
ML_CLIENT_ID=tu-client-id
ML_SELLER_ID=tu-seller-id
ML_CLIENT_SECRET=tu-client-secret
ML_REDIRECT_URI=https://tu-dominio/callback
ML_ACCESS_TOKEN=tu-access-token
ML_REFRESH_TOKEN=tu-refresh-token
ML_TOKEN_EXPIRES_IN=21600
ML_TOKEN_CREATED_AT=0
ML_TOKEN_EXPIRES_AT=0

# Firecrawl API - Obtener key en https://firecrawl.dev
FIRE_CRAWL_API_KEY=tu-firecrawl-key

# WooCommerce (si aplica)
WOO_CONSUMER_KEY=tu-consumer-key
WOO_CONSUMER_SECRET=tu-consumer-secret
WOO_BASE_URL=https://tu-tienda.com/wp-admin
WOO_API_VERSION=wc/v3
wp_user=tu-usuario-wp
wp_pass=tu-app-password-wp

# OpenAI
OPENAI_API_KEY=sk-tu-openai-key

# N8N
N8N_API_URL=http://tu-servidor-n8n:5678
N8N_API_KEY=tu-n8n-api-key

# Hostinger (para deploy automatizado)
hostinger_host=tu-host-hostinger
hostinger_port=22
hostinger_user=tu-usuario
hostinger_pass=tu-password

# Log
LOG_LEVEL=INFO
